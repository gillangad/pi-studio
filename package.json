{
  "name": "pi-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop Pi client with GUI and hosted TUI modes.",
  "bin": {
    "pistudio": "./bin/pistudio.js"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
